{
	"name": "owservable",
	"version": "2.1.1",
	"description": "owservable backend",
	"engines": {
		"node": ">=24.12.0"
	},
	"main": "./lib/owservable.js",
	"types": "./lib/owservable.d.ts",
	"author": "Predrag Stojadinovic <predrag@stojadinovic.net>",
	"license": "Unlicense",
	"files": [
		"lib/**/*"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/owservable/owservable.git"
	},
	"scripts": {
		"all": "yarn & yarn clean & yarn format & yarn build & skeletest -f & strictr -f & yarn test & yarn docs",
		"clear:lib": "del /S /Q lib\\*",
		"build": "yarn clear:lib & tsc",
		"build:watch": "tsc --watch",
		"lint": "eslint .",
		"clean": "eslint --fix .",
		"format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
		"docs": "typedoc --readme none --out docs ./src/owservable.ts",
		"sync": "git pull & git fetch origin & git merge origin/main & yarn & git branch",
		"test": "jest --coverage --config jest.config.js",
		"quick": "jest --config jest.config.js",
		"test:watch": "jest --watch --config jest.config.js",
		"coveralls": "cat ./coverage/lcov.info | node node_modules/.bin/coveralls",
		"test_qube": "jest --coverage --testResultsProcessor=jest-sonar-reporter --config jest.config.js",
		"up": "yarn upgrade-interactive",
		"latest": "yarn upgrade-interactive --latest",
		"l": "yarn & yarn latest",
		"audit-fix": "npx --yes yarn-audit-fix",
		"srctree": "dir src /s /b > srctree.txt"
	},
	"dependencies": {
		"@owservable/actions": "^2.1.1",
		"@owservable/folders": "^2.1.1",
		"@types/lodash": "^4.17.24",
		"@types/node": "^25.6.0",
		"@types/node-cron": "^3.0.11",
		"deprecated-decorator": "^0.1.6",
		"json-circular-stringify": "^1.0.1",
		"jsondiffpatch": "^0.5.0",
		"lodash": "^4.18.1",
		"mongoose": "^9.5.0",
		"node-cron": "^4.2.1",
		"rxjs": "^7.8.2",
		"sift": "^17.1.3"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/jest": "^30.0.0",
		"@types/rewire": "^2.5.30",
		"coveralls": "^3.0.9",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-sonarjs": "^4.0.3",
		"jest": "^30.3.0",
		"jest-sonar-reporter": "^2.0.0",
		"prettier": "^3.8.3",
		"rewire": "^9.0.1",
		"skeletest": "^0.7.5",
		"source-map-support": "^0.5.21",
		"strictr": "^0.5.7",
		"ts-jest": "^29.4.9",
		"ts-node": "^10.9.2",
		"typedoc": "^0.28.19",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.1"
	},
	"packageManager": "yarn@1.22.22"
}
